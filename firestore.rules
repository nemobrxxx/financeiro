rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Transaction Validation ---
    function isValidTransaction(data) {
      return data.keys().hasAll(['userId', 'type', 'amount', 'description', 'category', 'date']) &&
             data.keys().size() >= 6 &&
             data.userId == request.auth.uid &&
             data.type in ['income', 'expense'] &&
             data.amount is number && data.amount > 0 &&
             data.description is string && data.description.size() <= 500 &&
             data.category is string && data.category.size() <= 100 &&
             data.date is string; // Date stored as ISO string for simplicity in rules or timestamp
    }

    // --- Category Validation ---
    function isValidCategory(data) {
      return data.keys().hasAll(['userId', 'name', 'type']) &&
             data.userId == request.auth.uid &&
             data.name is string && data.name.size() <= 50 &&
             data.type in ['income', 'expense'];
    }

    // --- Collections ---

    match /transactions/{transactionId} {
      allow get: if isOwner(existing().userId);
      allow list: if isOwner(resource.data.userId);
      
      allow create: if isSignedIn() && 
                      isValidId(transactionId) && 
                      isValidTransaction(incoming()) &&
                      incoming().userId == request.auth.uid;
                      
      allow update: if isSignedIn() && 
                      isOwner(existing().userId) &&
                      isValidTransaction(incoming()) &&
                      incoming().userId == existing().userId &&
                      (
                        // Action: Edit - cannot change type or userId for stability, or just allow everything that passes validation
                        incoming().diff(existing()).affectedKeys().hasOnly(['amount', 'description', 'category', 'date', 'updatedAt'])
                      );
                      
      allow delete: if isOwner(existing().userId);
    }

    match /categories/{categoryId} {
      allow get: if isOwner(existing().userId);
      allow list: if isOwner(resource.data.userId);
      
      allow create: if isSignedIn() && 
                      isValidId(categoryId) && 
                      isValidCategory(incoming()) &&
                      incoming().userId == request.auth.uid;
                      
      allow update: if isSignedIn() && 
                      isOwner(existing().userId) &&
                      isValidCategory(incoming()) &&
                      incoming().userId == existing().userId &&
                      incoming().diff(existing()).affectedKeys().hasOnly(['name', 'type', 'color']);
                      
      allow delete: if isOwner(existing().userId);
    }
  }
}
